# Copy to .env.local and set your kooker APISIX gateway base URL.
# The browser calls /kooker/... which Vite proxies to this gateway (kooker-service-user etc.).
KOOKER_GATEWAY=https://your-kooker-gateway.example.com

# Operator login passcode for the Border Authority gate (dev soft-gate; the real gate is a backend JWT).
# VITE_-prefixed means it is bundled into the client, so this is NOT a real secret — use a throwaway value.
VITE_OPERATOR_PASSCODE=changeme
# Optional: set an operator name too and the dev server auto-logs-in as them (skips the gate locally).
# Leave blank to keep the manual login screen. Dev-only; never auto-logs-in a production build.
VITE_OPERATOR_NAME=

# NOTE: the old VITE_CITYLIFE_PAT is gone. CityLife bots now call the kooker inference choke point
# with the LOGGED-IN PLAYER'S OWN session JWT (obtained at login + auto-refreshed), so there is no
# shared PAT to configure. Just log in; bots reply live from kooker inference attributed to you.

# Low Power Radio — YouTube playlist ids per channel. YouTube handles licensing for the embed.
# Get a playlist id from any public YouTube playlist URL (e.g. youtube.com/playlist?list=PL...)
# All optional — channels with no playlist are disabled in the UI.
VITE_RADIO_PLAYLIST_DRIVE=
VITE_RADIO_PLAYLIST_COAST=
VITE_RADIO_PLAYLIST_SPACE=
VITE_RADIO_PLAYLIST_FOREST=
VITE_RADIO_PLAYLIST_INDUSTRY=
